# Teller - get from app.teller.io
TELLER_ACCESS_TOKEN=
TELLER_ACCOUNT_ID=
TELLER_CERT=teller_cert.pem     # path to your Teller certificate file
TELLER_KEY=teller_private_key.pem  # path to your Teller private key file

# Notion - get from notion.so/my-integrations
NOTION_TOKEN=

# Optional: how many days back to pull on each run
LOOKBACK_DAYS=7

# Only needed for scripts/link_account.py (one-time setup)
TELLER_APP_ID=
