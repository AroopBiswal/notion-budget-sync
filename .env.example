# LLM - set one (Anthropic takes priority if both are present)
# Get Anthropic key at console.anthropic.com
ANTHROPIC_API_KEY=
# Get OpenAI key at platform.openai.com
OPENAI_API_KEY=

# Notion - get token from notion.so/my-integrations
NOTION_TOKEN=
# Paste your database URL or 32-char ID (CLI uses this; web UI accepts the URL directly)
NOTION_DATABASE_ID=

# Set to true to use LLM for categorizing unmatched transactions (off by default)
LLM_CATEGORIZATION=false
